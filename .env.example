# Shopify Storefront API Configuration
# Copy this file to .env.local and fill in your values

# Your Shopify store domain (e.g., your-store.myshopify.com)
NEXT_PUBLIC_SHOPIFY_DOMAIN=your-store.myshopify.com

# Your Shopify Storefront API access token
# Get this from Shopify Admin > Settings > Apps and sales channels > Develop apps
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token

# Optional: Lock Upgrade Variant ID (for cart upsell)
# Get this from Shopify Admin: Products > Plunger Lock Upgrade > Variants > Copy Variant ID
# Format: gid://shopify/ProductVariant/XXXXXXXXX
# NEXT_PUBLIC_SHOPIFY_LOCK_UPGRADE_VARIANT_ID=gid://shopify/ProductVariant/XXXXXXXXX